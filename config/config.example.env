# server-pulse configuration
# Location: /etc/server-pulse/config.env
# Permissions: chown root:root && chmod 600 (installer does this)
#
# Docs: https://github.com/volkv/server-pulse/blob/main/docs/configuration.md

# ─────────────────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=""

# Telegram chat ID (user, group, or channel). See docs/telegram-setup.md
TELEGRAM_CHAT_ID=""

# Server identifier shown in every alert. Defaults to `hostname -s`.
# SERVER_NAME="my-server"

# ─────────────────────────────────────────────────────────────────────────
# Outbound proxy (optional)
# Useful when the Telegram API is blocked from your server (e.g. RKN).
# ─────────────────────────────────────────────────────────────────────────

# OUTBOUND_PROXY_URI="http://proxy.example.com:9999"
# OUTBOUND_PROXY_AUTH="username:password"

# ─────────────────────────────────────────────────────────────────────────
# Mission Control (optional)
# Mirror WARN/CRIT/RESOLVED alerts into the Mission Control fleet timeline
# (POST /api/ingest/server). Both must be set or the sink is a no-op. The token
# needs the `write` scope. Events are attributed to a project by matching
# SERVER_NAME against the host registered in Mission Control (projects.host).
# ─────────────────────────────────────────────────────────────────────────

# MC_URL="https://mc.volkv.com"
# MC_TOKEN=""

# ─────────────────────────────────────────────────────────────────────────
# Thresholds
# ─────────────────────────────────────────────────────────────────────────

# Disk usage (%)
DISK_WARN_PCT=85
DISK_CRIT_PCT=95

# Inode usage (%)
INODE_WARN_PCT=85
INODE_CRIT_PCT=95

# RAM usage (%) — based on MemAvailable
RAM_WARN_PCT=85
RAM_CRIT_PCT=95

# Swap usage (%)
SWAP_WARN_PCT=50
SWAP_CRIT_PCT=80

# Load average (5 min) multiplier relative to logical CPU count
LOAD_WARN_MULT=1.5
LOAD_CRIT_MULT=3.0

# CPU usage (%) — instantaneous sample over 1 second
CPU_WARN_PCT=85
CPU_CRIT_PCT=95

# ─────────────────────────────────────────────────────────────────────────
# Check toggles
# ─────────────────────────────────────────────────────────────────────────

CHECK_DISK=true
CHECK_INODE=true
CHECK_MEMORY=true
CHECK_LOAD=true
CHECK_CPU=true
CHECK_OOM=true
CHECK_DOCKER=false
CHECK_SYSTEMD=false

# Allowlist: Docker containers to watch (space-separated). Required if CHECK_DOCKER=true.
DOCKER_CONTAINERS=""

# Allowlist: systemd units to watch (space-separated). Required if CHECK_SYSTEMD=true.
SYSTEMD_UNITS=""

# Mountpoints excluded from disk / inode checks (bash regex on mountpoint).
DISK_EXCLUDE_REGEX="^/(dev|proc|sys|run|snap|var/lib/docker)"

# ─────────────────────────────────────────────────────────────────────────
# Throttling
# ─────────────────────────────────────────────────────────────────────────

# Minimum minutes between repeated WARNING messages for the same check.
WARN_THROTTLE_MIN=60

# Minimum minutes between repeated CRITICAL messages for the same check.
CRIT_THROTTLE_MIN=30

# Send a RESOLVED message when a check returns to OK.
RESOLVED_NOTIFY=true
